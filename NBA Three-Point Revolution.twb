                <zone h='6301' id='11' mode='dropdown' name='Shot Zones Over Time' param='[federated.1c37n880r97gae1ccn3pa15j4k63].[none:Calculation_2862306141237285:nk]' type-v2='filter' values='database' w='10323' x='76903' y='10852'>
                  <zone-style>
