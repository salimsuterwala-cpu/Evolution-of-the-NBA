    <worksheet name='Net Rating Distr'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#ffffff' fontsize='14'>Net Rating Distribution — Teams with 3+ High-Volume Shooters</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='NBA_Players_Report+' name='federated.1c37n880r97gae1ccn3pa15j4k63' />
          </datasources>
          <datasource-dependencies datasource='federated.1c37n880r97gae1ccn3pa15j4k63'>
            <column caption='Qualified Players' datatype='boolean' name='[Calculation_2862305406185475]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[minutes_played] &gt;= 1500' />
            </column>
            <column caption='Net Rating Bucket' datatype='string' name='[Calculation_2862305601077256]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [n_rtg] &gt;= 10 THEN &apos;Elite  (&gt;= +10)&apos;&#13;&#10;ELSEIF [n_rtg] &gt;= 5  THEN &apos;Strong (+5 to +10)&apos;&#13;&#10;ELSEIF [n_rtg] &gt;= 0  THEN &apos;Average (0 to +5)&apos;&#13;&#10;ELSEIF [n_rtg] &gt;= -5 THEN &apos;Weak   (-5 to 0)&apos;&#13;&#10;ELSE &apos;Poor  (&lt; -5)&apos;&#13;&#10;END' />
            </column>
            <column caption='High 3PA Count per Team  ' datatype='integer' name='[Calculation_2862305619226641]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{FIXED [team], [season]:&#13;&#10; COUNTD(IF[three_attempt_rt] &gt; 0.30&#13;&#10; AND [minutes_played] &gt;= 1500&#13;&#10; THEN [player_id] END)}' />
            </column>
            <column caption='Era' datatype='string' name='[Calculation_2862306027986970]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [season (NBA_Teams_Report.csv)] &gt;= 1980 AND [season (NBA_Teams_Report.csv)] &lt;= 1989 THEN &apos;(1980-1989) Era 1&apos;&#13;&#10;ELSEIF [season (NBA_Teams_Report.csv)] &gt;= 1990 AND [season (NBA_Teams_Report.csv)] &lt;= 1999 THEN &apos;(1990-1999) Era 2&apos;&#13;&#10;ELSEIF [season (NBA_Teams_Report.csv)] &gt;= 2000 AND [season (NBA_Teams_Report.csv)] &lt;= 2012 THEN &apos;(2000-2012) Era 3&apos;&#13;&#10;ELSEIF [season (NBA_Teams_Report.csv)] &gt;= 2013 AND [season (NBA_Teams_Report.csv)] &lt;= 2025 THEN &apos;(2013-2025) Era 4&apos;&#13;&#10;ELSE NULL &#13;&#10;END' />
            </column>
            <column-instance column='[Calculation_2862305619226641]' derivation='Count' name='[cnt:Calculation_2862305619226641:qk]' pivot='key' type='quantitative' />
            <column-instance column='[team (NBA_Teams_Report.csv)]' derivation='Count' name='[cnt:team (NBA_Teams_Report.csv):qk]' pivot='key' type='quantitative' />
            <column caption='Minutes Played' datatype='integer' name='[minutes_played]' role='measure' type='quantitative' />
            <column caption='N Rtg' datatype='real' name='[n_rtg]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_2862305406185475]' derivation='None' name='[none:Calculation_2862305406185475:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_2862305601077256]' derivation='None' name='[none:Calculation_2862305601077256:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_2862306027986970]' derivation='None' name='[none:Calculation_2862306027986970:nk]' pivot='key' type='nominal' />
            <column-instance column='[season (NBA_Teams_Report.csv)]' derivation='None' name='[none:season (NBA_Teams_Report.csv):ok]' pivot='key' type='ordinal' />
            <column-instance column='[team (NBA_Teams_Report.csv)]' derivation='None' name='[none:team (NBA_Teams_Report.csv):nk]' pivot='key' type='nominal' />
            <column-instance column='[team]' derivation='None' name='[none:team:nk]' pivot='key' type='nominal' />
            <column caption='Player Id' datatype='string' name='[player_id]' role='dimension' type='nominal' />
            <column caption='season -Teams' datatype='integer' name='[season (NBA_Teams_Report.csv)]' role='dimension' type='ordinal' />
            <column caption='Season' datatype='integer' name='[season]' role='dimension' type='ordinal' />
            <column caption='Teams' datatype='string' name='[team (NBA_Teams_Report.csv)]' role='dimension' type='nominal' />
            <column caption='Team' datatype='string' name='[team]' role='dimension' type='nominal' />
            <column caption='3PA Rate' datatype='real' name='[three_attempt_rt]' role='measure' type='quantitative' />
          </datasource-dependencies>
