      <aliases enabled='yes' />
      <column caption='TOV vs Pace Correlation (copy)' datatype='real' name='[3PA vs Pace Correlation (copy)_3963192386932736]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CORR([tov_per_100poss (NBA_Teams_Report.csv)], [pace])' />
      </column>
      <column datatype='real' default-format='p0.00%' name='[Calculation1]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([team (NBA_Teams_Report.csv)]) / TOTAL(COUNT([team (NBA_Teams_Report.csv)]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column datatype='real' default-format='p0.00%' name='[Calculation2]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([player]) / TOTAL(COUNTD([player]))'>
          <table-calc ordering-type='Field'>
            <order field='[federated.1c37n880r97gae1ccn3pa15j4k63].[none:Calculation_2862305390456832:nk]' />
            <order field='[federated.1c37n880r97gae1ccn3pa15j4k63].[none:Calculation_2862305391108098:nk]' />
          </table-calc>
        </calculation>
      </column>
      <column caption='Eras - Top Players' datatype='string' name='[Calculation_2862305390456832]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [season] &gt;= 1980 AND [season] &lt;= 1989 THEN &apos;(1980-1989) Era 1&apos;&#13;&#10;ELSEIF [season] &gt;= 1990 AND [season] &lt;= 1999 THEN &apos;(1990-1999) Era 2&apos;&#13;&#10;ELSEIF [season] &gt;= 2000 AND [season] &lt;= 2012 THEN &apos;(2000-2012) Era 3&apos;&#13;&#10;ELSEIF [season] &gt;= 2013 AND [season] &lt;= 2025 THEN &apos;(2013-2025) Era 4&apos;&#13;&#10;ELSE NULL&#13;&#10;END' />
      </column>
      <column caption='Positions' datatype='string' name='[Calculation_2862305390899201]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [position] = &apos;PG&apos; THEN &apos;Guard&apos;&#13;&#10;ELSEIF [position] = &apos;SG&apos; THEN &apos;Guard&apos;&#13;&#10;ELSEIF [position] = &apos;SF&apos; THEN &apos;Wing&apos;&#13;&#10;ELSEIF [position] = &apos;PF&apos; THEN &apos;Big&apos;&#13;&#10;ELSEIF [position] = &apos;C&apos;  THEN &apos;Big&apos;&#13;&#10;ELSE NULL&#13;&#10;END' />
      </column>
      <column caption='Stretch Big' datatype='string' name='[Calculation_2862305391108098]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF ([position] = &apos;C&apos; OR [position] = &apos;PF&apos;) AND [three_attempt_rt] &gt; 0.10 THEN &apos;Stretch Big&apos;&#13;&#10;ELSEIF ([position] = &apos;C&apos; OR [position] = &apos;PF&apos;) AND [three_attempt_rt] &lt;= 0.10 THEN &apos;Traditional Big&apos;&#13;&#10;ELSE NULL&#13;&#10;END' />
      </column>
      <column caption='Qualified Players' datatype='boolean' name='[Calculation_2862305406185475]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[minutes_played] &gt;= 1500' />
      </column>
      <column caption='Era - Shot Zones' datatype='string' name='[Calculation_2862305597333508]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [season] &gt;= 1997 AND [season] &lt;= 2005 THEN &quot;Era 1 (1997-2005)&quot;&#13;&#10;ELSEIF [season] &gt;= 2006 AND [season] &lt;= 2012 THEN &quot;Era 2 (2006-2012)&quot;&#13;&#10;ELSEIF [season] &gt;= 2013 AND [season] &lt;= 2025 THEN &quot;Era 3 (2013-2025)&quot;&#13;&#10;ELSE NULL END' />
      </column>
      <column caption='Big Man' datatype='boolean' name='[Calculation_2862305597960197]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[position] = &apos;C&apos; OR [position] = &apos;PF&apos;' />
      </column>
      <column caption='Minutes Weighted 3PA Rate' datatype='real' name='[Calculation_2862305599594503]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[three_attempt_rt] * [minutes_played]' />
      </column>
      <column caption='Net Rating Bucket' datatype='string' name='[Calculation_2862305601077256]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [n_rtg] &gt;= 10 THEN &apos;Elite  (&gt;= +10)&apos;&#13;&#10;ELSEIF [n_rtg] &gt;= 5  THEN &apos;Strong (+5 to +10)&apos;&#13;&#10;ELSEIF [n_rtg] &gt;= 0  THEN &apos;Average (0 to +5)&apos;&#13;&#10;ELSEIF [n_rtg] &gt;= -5 THEN &apos;Weak   (-5 to 0)&apos;&#13;&#10;ELSE &apos;Poor  (&lt; -5)&apos;&#13;&#10;END' />
      </column>
      <column caption='Mid-Range % ' datatype='real' name='[Calculation_2862305601511433]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ZN([fga_percent_10to16ft]) + ZN([fga_percent_16to3p]) * 100' />
      </column>
      <column caption='High 3PA Rate' datatype='integer' name='[Calculation_2862305602523147]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='{FIXED [team], [season]:&#13;&#10;COUNTD(IF [three_attempt_rt] &gt; 0.30&#13;&#10;AND [minutes_played] &gt;= 1500&#13;&#10;THEN [player] END)}' />
      </column>
      <column caption='Champion' datatype='string' name='[Calculation_2862305602981900]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [season (NBA_Teams_Report.csv)] = 1987 AND [team (NBA_Teams_Report.csv)] = &apos;LAL&apos; THEN &apos;Champion&apos;&#13;&#10;ELSEIF [season (NBA_Teams_Report.csv)] = 1996 AND [team (NBA_Teams_Report.csv)] = &apos;CHI&apos; THEN &apos;Champion&apos;&#13;&#10;ELSEIF [season (NBA_Teams_Report.csv)] = 2005 AND [team (NBA_Teams_Report.csv)] = &apos;SAS&apos; THEN &apos;Champion&apos;&#13;&#10;ELSEIF [season (NBA_Teams_Report.csv)] = 2015 AND [team (NBA_Teams_Report.csv)] = &apos;GSW&apos; THEN &apos;Champion&apos;&#13;&#10;ELSE &apos;Other Teams&apos;&#13;&#10;END' />
      </column>
      <column caption='3pt Share - Players' datatype='real' name='[Calculation_2862305603477517]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([total_3p_scored]) / NULLIF(SUM([p_total_pts]), 0)' />
      </column>
      <column caption='Team 3PA Leader Flag' datatype='boolean' name='[Calculation_2862305603932174]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='{FIXED [team], [season] : MAX([total_3pa])} = [total_3pa]' />
      </column>
      <column caption='High 3PA Count per Team  ' datatype='integer' name='[Calculation_2862305619226641]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [team], [season]:&#13;&#10; COUNTD(IF[three_attempt_rt] &gt; 0.30&#13;&#10; AND [minutes_played] &gt;= 1500&#13;&#10; THEN [player_id] END)}' />
      </column>
      <column caption='0-3ft' datatype='real' name='[Calculation_2862305641357330]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([fga_percent_0to3ft] * [minutes_played]) / SUM([minutes_played]) *100' />
      </column>
      <column caption='3-10ft' datatype='real' name='[Calculation_2862305653239827]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([fga_percent_3to10ft] * [minutes_played]) / SUM([minutes_played]) * 100' />
      </column>
      <column caption='10-16ft' datatype='real' name='[Calculation_2862305653600276]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([fga_percent_10to16ft] * [minutes_played]) / SUM([minutes_played]) * 100' />
      </column>
      <column caption='16ft-3P' datatype='real' name='[Calculation_2862305654042645]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([fg_percent_16ft3p] * [minutes_played]) / SUM([minutes_played]) * 100' />
      </column>
      <column caption='3-Point' datatype='real' name='[Calculation_2862305654419478]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([three_attempt_rt] * [minutes_played]) / SUM([minutes_played]) * 100' />
      </column>
      <column caption='High 3PA Count per Team' datatype='integer' name='[Calculation_2862305655738392]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [team], [season]:&#13;&#10;COUNTD(IF [three_attempt_rt] &gt; 0.30&#13;&#10;AND [minutes_played] &gt;= 1500&#13;&#10;THEN [player_id] &#13;&#10;END)}' />
      </column>
      <column caption='Pace Tier' datatype='string' name='[Calculation_2862306017320985]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [pace] &gt;= 100 THEN &apos;Fast (&gt;= 100 poss)&apos;&#13;&#10;ELSEIF [pace] &gt;= 95 THEN &apos;Moderate (95-99)&apos;&#13;&#10;ELSEIF [pace] &gt;= 90 THEN &apos;Slow (90-94)&apos;&#13;&#10;ELSE &apos;Very Slow (&lt; 90)&apos;&#13;&#10;END' />
      </column>
      <column caption='Era' datatype='string' name='[Calculation_2862306027986970]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [season (NBA_Teams_Report.csv)] &gt;= 1980 AND [season (NBA_Teams_Report.csv)] &lt;= 1989 THEN &apos;(1980-1989) Era 1&apos;&#13;&#10;ELSEIF [season (NBA_Teams_Report.csv)] &gt;= 1990 AND [season (NBA_Teams_Report.csv)] &lt;= 1999 THEN &apos;(1990-1999) Era 2&apos;&#13;&#10;ELSEIF [season (NBA_Teams_Report.csv)] &gt;= 2000 AND [season (NBA_Teams_Report.csv)] &lt;= 2012 THEN &apos;(2000-2012) Era 3&apos;&#13;&#10;ELSEIF [season (NBA_Teams_Report.csv)] &gt;= 2013 AND [season (NBA_Teams_Report.csv)] &lt;= 2025 THEN &apos;(2013-2025) Era 4&apos;&#13;&#10;ELSE NULL &#13;&#10;END' />
      </column>
      <column caption='3pt Share - Teams' datatype='real' name='[Calculation_2862306030084124]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([total_3p_scored]) / NULLIF(SUM([total_pts]), 0)) * 100' />
      </column>
      <column caption='Pace-Adjusted 3PA Rate' datatype='real' name='[Calculation_2862306051682333]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_2862306053537823] * ([Calculation_2862306052378654]/WINDOW_AVG([Calculation_2862306052378654]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Avg Pace' datatype='real' name='[Calculation_2862306052378654]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([pace])' />
      </column>
      <column caption='Avg 3pt Attempts' datatype='real' name='[Calculation_2862306053537823]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([attempted_3p_per_100poss (NBA_Teams_Report.csv)])' />
      </column>
      <column caption='Avg TO Rate' datatype='real' name='[Calculation_2862306054004768]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(ZN([tov_percent]))' />
      </column>
      <column caption='Pace-Adj Tov Rate' datatype='real' name='[Calculation_2862306054455329]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_2862306054004768] * ([Calculation_2862306052378654] / WINDOW_AVG([Calculation_2862306052378654]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='3PA vs Pace Correlation' datatype='real' name='[Calculation_2862306054950946]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CORR([attempted_3p_per_100poss (NBA_Teams_Report.csv)], [pace])' />
      </column>
      <column caption='Avg 3PA Rate' datatype='real' name='[Calculation_2862306132443172]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ROUND(AVG([three_attempt_rt]), 4) * 100' />
      </column>
      <column caption='Pos' datatype='string' name='[Calculation_2862306141237285]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [position] = &apos;C&apos; THEN &apos;C&apos;&#13;&#10;ELSEIF [position] = &apos;PF&apos; THEN &apos;PF&apos;&#13;&#10;ELSE NULL&#13;&#10;END' />
      </column>
      <column caption='Stretch Big Share ' datatype='real' name='[Calculation_3963192807342090]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ROUND(COUNTD(IF  [Calculation_2862305391108098] = &apos;Stretch Big&apos; THEN [player_id] END) / COUNTD([player_id]), 4) * 100' />
      </column>
      <column caption='Total 3PA Rate' datatype='real' name='[Calculation_3963192822333451]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ROUND(SUM([three_attempt_rt]), 2) * 100' />
      </column>
