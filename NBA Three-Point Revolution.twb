      <table>
        <view>
          <datasources>
            <datasource caption='NBA_Players_Report+' name='federated.1c37n880r97gae1ccn3pa15j4k63' />
          </datasources>
          <datasource-dependencies datasource='federated.1c37n880r97gae1ccn3pa15j4k63'>
            <column caption='Qualified Players' datatype='boolean' name='[Calculation_2862305406185475]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[minutes_played] &gt;= 1500' />
            </column>
            <column caption='0-3ft' datatype='real' name='[Calculation_2862305641357330]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([fga_percent_0to3ft] * [minutes_played]) / SUM([minutes_played]) *100' />
            </column>
            <column caption='3-10ft' datatype='real' name='[Calculation_2862305653239827]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([fga_percent_3to10ft] * [minutes_played]) / SUM([minutes_played]) * 100' />
            </column>
            <column caption='10-16ft' datatype='real' name='[Calculation_2862305653600276]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([fga_percent_10to16ft] * [minutes_played]) / SUM([minutes_played]) * 100' />
            </column>
            <column caption='16ft-3P' datatype='real' name='[Calculation_2862305654042645]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([fg_percent_16ft3p] * [minutes_played]) / SUM([minutes_played]) * 100' />
            </column>
            <column caption='3-Point' datatype='real' name='[Calculation_2862305654419478]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([three_attempt_rt] * [minutes_played]) / SUM([minutes_played]) * 100' />
            </column>
            <column caption='Pos' datatype='string' name='[Calculation_2862306141237285]' role='dimension' type='nominal'>
