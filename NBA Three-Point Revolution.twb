  <worksheets>
    <worksheet name='3PA &amp; TOV vs Pace Correlation'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#ffffff' fontsize='14'>&lt;Sheet Name&gt;</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='NBA_Players_Report+' name='federated.1c37n880r97gae1ccn3pa15j4k63' />
          </datasources>
          <datasource-dependencies datasource='federated.1c37n880r97gae1ccn3pa15j4k63'>
            <column caption='TOV vs Pace Correlation (copy)' datatype='real' name='[3PA vs Pace Correlation (copy)_3963192386932736]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CORR([tov_per_100poss (NBA_Teams_Report.csv)], [pace])' />
            </column>
            <column caption='Pace Tier' datatype='string' name='[Calculation_2862306017320985]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [pace] &gt;= 100 THEN &apos;Fast (&gt;= 100 poss)&apos;&#13;&#10;ELSEIF [pace] &gt;= 95 THEN &apos;Moderate (95-99)&apos;&#13;&#10;ELSEIF [pace] &gt;= 90 THEN &apos;Slow (90-94)&apos;&#13;&#10;ELSE &apos;Very Slow (&lt; 90)&apos;&#13;&#10;END' />
            </column>
            <column caption='Era' datatype='string' name='[Calculation_2862306027986970]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [season (NBA_Teams_Report.csv)] &gt;= 1980 AND [season (NBA_Teams_Report.csv)] &lt;= 1989 THEN &apos;(1980-1989) Era 1&apos;&#13;&#10;ELSEIF [season (NBA_Teams_Report.csv)] &gt;= 1990 AND [season (NBA_Teams_Report.csv)] &lt;= 1999 THEN &apos;(1990-1999) Era 2&apos;&#13;&#10;ELSEIF [season (NBA_Teams_Report.csv)] &gt;= 2000 AND [season (NBA_Teams_Report.csv)] &lt;= 2012 THEN &apos;(2000-2012) Era 3&apos;&#13;&#10;ELSEIF [season (NBA_Teams_Report.csv)] &gt;= 2013 AND [season (NBA_Teams_Report.csv)] &lt;= 2025 THEN &apos;(2013-2025) Era 4&apos;&#13;&#10;ELSE NULL &#13;&#10;END' />
            </column>
            <column caption='3PA vs Pace Correlation' datatype='real' name='[Calculation_2862306054950946]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CORR([attempted_3p_per_100poss (NBA_Teams_Report.csv)], [pace])' />
            </column>
            <column caption='attempted 3p per 100poss (NBA Teams Report.csv)' datatype='real' name='[attempted_3p_per_100poss (NBA_Teams_Report.csv)]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_2862306017320985]' derivation='None' name='[none:Calculation_2862306017320985:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_2862306027986970]' derivation='None' name='[none:Calculation_2862306027986970:nk]' pivot='key' type='nominal' />
            <column-instance column='[team (NBA_Teams_Report.csv)]' derivation='None' name='[none:team (NBA_Teams_Report.csv):nk]' pivot='key' type='nominal' />
            <column caption='Pace' datatype='real' name='[pace]' role='measure' type='quantitative' />
            <column caption='season -Teams' datatype='integer' name='[season (NBA_Teams_Report.csv)]' role='dimension' type='ordinal' />
            <column caption='Teams' datatype='string' name='[team (NBA_Teams_Report.csv)]' role='dimension' type='nominal' />
            <column caption='tov per 100poss (NBA Teams Report.csv)' datatype='real' name='[tov_per_100poss (NBA_Teams_Report.csv)]' role='measure' type='quantitative' />
            <column-instance column='[3PA vs Pace Correlation (copy)_3963192386932736]' derivation='User' name='[usr:3PA vs Pace Correlation (copy)_3963192386932736:qk]' pivot='key' type='quantitative' />
